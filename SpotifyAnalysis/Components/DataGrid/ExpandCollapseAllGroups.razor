@namespace SpotifyAnalysis.Components
@typeparam T

<MudButtonGroup Variant="Variant.Outlined" Class="pl-6">
	<MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowUp" aria-label="Collapse all" Disabled=!DataGrid.IsGrouped OnClick=CollapseAll />
	<MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown" aria-label="Expand all" Disabled=!DataGrid.IsGrouped OnClick=ExpandAll />
</MudButtonGroup>

@code {
	[Parameter, EditorRequired]
	public MudDataGrid<T> DataGrid { get; set; }

	async Task ExpandAll() => await DataGrid?.ExpandAllGroupsAsync();
	async Task CollapseAll() => await DataGrid?.CollapseAllGroupsAsync();
}
